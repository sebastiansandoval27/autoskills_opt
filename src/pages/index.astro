---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

interface SvglEntry {
  title: string;
  route: string | { light: string; dark: string };
}

const SVGL_OVERRIDES: Record<string, string> = {
  'React Native': 'React',
  'Vercel AI SDK': 'Vercel',
  'Azure': 'Microsoft Azure',
  'SwiftUI': 'Swift',
  'AWS': 'Amazon Web Services',
  'Durable Objects': 'Cloudflare Workers',
  'Cloudflare Agents': 'Cloudflare Workers',
  'Cloudflare AI': 'Cloudflare Workers',
  'Express': 'Express.js',
  'Node.js': 'Node.js',
};

const INLINE_SVGS: Record<string, string> = {
  'ElevenLabs': `<svg width="876" height="876" viewBox="0 0 876 876" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M468 292H528V584H468V292Z" fill="white"/><path d="M348 292H408V584H348V292Z" fill="white"/></svg>`,
