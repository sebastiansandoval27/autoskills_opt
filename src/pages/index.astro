5.197.222l-.127-.116a3.765 3.765 0 0 1-.105-5.324l23.1-24.036-16.284-17.324a3.765 3.765 0 0 1 .042-5.2l.123-.121a3.765 3.765 0 0 1 5.321.164l16.021 17.044 22.331-23.235Z"/><path fill="#FFC73B" d="M136.602 126.74a3.765 3.765 0 0 1 0 5.323l-17.53 17.531 10.684 10.686a3.765 3.765 0 0 1 .12 5.2l-.12.125a3.765 3.765 0 0 1-5.324 0l-10.686-10.686-10.686 10.686a3.765 3.765 0 1 1-5.324-5.325l10.685-10.686-17.53-17.53a3.765 3.765 0 0 1-.12-5.2l.12-.125a3.765 3.765 0 0 1 5.324 0l17.531 17.53 17.531-17.53a3.765 3.765 0 0 1 5.325 0Z"/></svg>`,
};

const skillsMap = [
  { name: 'React', skills: ['vercel-labs/agent-skills/vercel-react-best-practices', 'vercel-labs/agent-skills/vercel-composition-patterns'] },
  { name: 'Next.js', skills: ['vercel-labs/next-skills/next-best-practices', 'vercel-labs/next-skills/next-cache-components', 'vercel-labs/next-skills/next-upgrade'] },
  { name: 'Vue', skills: ['hyf0/vue-skills/vue-best-practices', 'hyf0/vue-skills/vue-debug-guides', 'antfu/skills/vue', 'antfu/skills/vue-best-practices'] },
  { name: 'Nuxt', skills: ['antfu/skills/nuxt'] },
  { name: 'Pinia', skills: ['vuejs-ai/skills/vue-pinia-best-practices'] },
  { name: 'Astro', skills: ['astrolicious/agent-skills/astro'] },
  { name: 'Svelte', skills: [] },
  { name: 'Angular', skills: [] },
  { name: 'Tailwind CSS', skills: ['giuseppe-trisciuoglio/developer-kit/tailwind-css-patterns'] },
  { name: 'shadcn/ui', skills: ['shadcn/ui/shadcn'] },
  { name: 'TypeScript', skills: ['wshobson/agents/typescript-advanced-types'] },
  { name: 'Playwright', skills: ['currents-dev/playwright-best-practices-skill/playwright-best-practices'] },
  { name: 'Supabase', skills: ['supabase/agent-skills/supabase-postgres-best-practices'] },
  { name: 'Neon', skills: ['neondatabase/agent-skills/neon-postgres'] },
  { name: 'Expo', skills: ['expo/skills/building-native-ui', 'expo/skills/native-data-fetching', 'expo/skills/upgrading-expo', 'expo/skills/expo-tailwind-setup', 'expo/skills/expo-dev-client', 'expo/skills/expo-deployment', 'expo/skills/expo-cicd-workflows', 'expo/skills/expo-api-routes', 'expo/skills/use-dom'] },
  { name: 'React Native', skills: ['sleekdotdesign/agent-skills/sleek-design-mobile-apps'] },
  { name: 'Remotion', skills: ['remotion-dev/skills/remotion-best-practices'] },
  { name: 'Better Auth', skills: ['better-auth/skills/better-auth-best-practices', 'better-auth/skills/email-and-password-best-practices', 'better-auth/skills/organization-best-practices', 'better-auth/skills/two-factor-authentication-best-practices'] },
  { name: 'Turborepo', skills: ['vercel/turborepo/turborepo'] },
  { name: 'Vite', skills: ['antfu/skills/vite'] },
  { name: 'Azure', skills: ['microsoft/github-copilot-for-azure/azure-deploy', 'microsoft/github-copilot-for-azure/azure-ai', 'microsoft/github-copilot-for-azure/azure-cost-optimization', 'microsoft/github-copilot-for-azure/azure-diagnostics'] },
  { name: 'Vercel AI SDK', skills: ['vercel/ai/ai-sdk'] },
  { name: 'Vercel', skills: ['vercel-labs/agent-skills/deploy-to-vercel'] },
  { name: 'ElevenLabs', skills: ['inferen-sh/skills/elevenlabs-tts', 'inferen-sh/skills/elevenlabs-music'] },
  { name: 'Cloudflare', skills: ['cloudflare/skills/cloudflare', 'cloudflare/skills/wrangler', 'cloudflare/skills/workers-best-practices', 'cloudflare/skills/web-perf', 'openai/skills/cloudflare-deploy'] },
  { name: 'Durable Objects', skills: ['cloudflare/skills/durable-objects'] },
  { name: 'Cloudflare Agents', skills: ['cloudflare/skills/agents-sdk', 'cloudflare/skills/building-mcp-server-on-cloudflare', 'cloudflare/skills/sandbox-sdk'] },
  { name: 'Cloudflare AI', skills: ['cloudflare/skills/building-ai-agent-on-cloudflare'] },
  { name: 'AWS', skills: [] },
  { name: 'SwiftUI', skills: ['avdlee/swiftui-agent-skill/swiftui-expert-skill'] },
  { name: 'oxlint', skills: ['delexw/claude-code-misc/oxlint'] },
  { name: 'GSAP', skills: ['greensock/gsap-skills/gsap-core', 'greensock/gsap-skills/gsap-scrolltrigger', 'greensock/gsap-skills/gsap-performance', 'greensock/gsap-skills/gsap-plugins', 'greensock/gsap-skills/gsap-timeline', 'greensock/gsap-skills/gsap-utils', 'greensock/gsap-skills/gsap-frameworks'] },
  { name: 'Node.js', skills: ['wshobson/agents/nodejs-backend-patterns', 'sickn33/antigravity-awesome-skills/nodejs-best-practices'] },
  { name: 'Express', skills: [] },
  { name: 'Bun', skills: ['https://bun.sh/docs'] },
  { name: 'Deno', skills: ['denoland/skills/deno-expert', 'denoland/skills/deno-guidance', 'denoland/skills/deno-frontend', 'denoland/skills/deno-deploy', 'denoland/skills/deno-sandbox', 'mindrally/skills/deno-typescript'] },
];

const technologies = skillsMap.map((s) => s.name);

let svgMap: Record<string, string> = {};
try {
  const res = await fetch('https://api.svgl.app?limit=2000');
  const data: SvglEntry[] = await res.json();

  for (const tech of technologies) {
    const searchTitle = SVGL_OVERRIDES[tech] || tech;
    const match = data.find(
      (s) => s.title.toLowerCase() === searchTitle.toLowerCase()
    );
    if (match) {
      svgMap[tech] = typeof match.route === 'string'
        ? match.route
        : (match.route.dark || match.route.light);
    }
  }
} catch {
  // Build continues without logos if API is down
}
---

<Layout>
  <!-- Left column: scrollable content -->
  <main class="text-sm leading-relaxed px-6 py-12 lg:w-1/2 lg:pl-12 lg:pr-8 lg:py-16">

    <!-- ASCII Logo (animated reveal) -->
    <pre id="ascii-logo" class="text-[10px] sm:text-xs lg:text-[9px] leading-none mb-8 h-[6lh] overflow-hidden" aria-hidden="true"></pre>

    <p class="text-zinc-400 mb-2">Auto-detect your tech stack and install the best</p>
    <p class="text-zinc-400 mb-8">AI agent skills for your project.</p>

    <!-- Install command -->
    <div class="mb-12">
      <p class="text-zinc-600 mb-2 uppercase tracking-widest text-xs">Try it now</p>
      <div class="flex items-center gap-3 bg-zinc-900/80 border border-zinc-800 px-4 py-3 w-fit cursor-pointer group" id="install-cmd">
        <span class="text-zinc-600">$</span>
        <span class="text-zinc-100">npx autoskills</span>
        <button
          class="ml-6 text-zinc-600 hover:text-zinc-300 transition-colors"
          aria-label="Copy command"
          id="copy-btn"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
          </svg>
        </button>
      </div>
    </div>

    <!-- Terminal (mobile/tablet only — on desktop it's the fixed right panel) -->
    <div class="mb-16 lg:fixed lg:top-0 lg:right-0 lg:w-1/2 lg:h-screen lg:mb-0 lg:flex lg:flex-col lg:p-8 xl:p-12 lg:border-l lg:border-zinc-800/50 lg:z-10">
      <p class="text-zinc-600 mb-2 uppercase tracking-widest text-xs lg:hidden">Output</p>
      <div class="border border-zinc-800 bg-zinc-950 lg:w-full lg:rounded-lg lg:overflow-hidden lg:shadow-2xl lg:shadow-black/20 lg:flex lg:flex-col lg:max-h-full" id="terminal">
        <div class="flex items-center gap-1.5 px-3 py-2 border-b border-zinc-800 shrink-0">
          <span class="w-2.5 h-2.5 rounded-full bg-zinc-800"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-zinc-800"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-zinc-800"></span>
        </div>
        <div class="p-4 text-xs leading-relaxed overflow-x-auto whitespace-pre min-h-[420px] lg:min-h-0 lg:overflow-y-auto lg:flex-1" id="term-body"></div>
      </div>
    </div>

    <!-- Separator -->
    <div class="text-zinc-700 mb-12">{'─'.repeat(48)}</div>

    <!-- How it works -->
    <div class="mb-12">
      <p class="text-zinc-600 mb-6 uppercase tracking-widest text-xs">How it works</p>
      <div class="space-y-4">
        <div class="flex gap-4">
          <span class="text-zinc-600 shrink-0">[1]</span>
          <div>
            <p class="text-zinc-200">Run the command</p>
            <p class="text-zinc-500">Execute <span class="text-zinc-400">npx autoskills</span> in your project root.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <span class="text-zinc-600 shrink-0">[2]</span>
          <div>
            <p class="text-zinc-200">Auto-detect</p>
            <p class="text-zinc-500">Scans your package.json and config files to detect your stack.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <span class="text-zinc-600 shrink-0">[3]</span>
          <div>
            <p class="text-zinc-200">Install skills</p>
            <p class="text-zinc-500">The best AI agent skills are installed automatically via <span class="text-zinc-400">skills.sh</span>.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Separator -->
    <div class="text-zinc-700 mb-12">{'─'.repeat(48)}</div>

    <!-- Supported Technologies & Skills -->
    <div class="mb-12">
      <p class="text-zinc-600 mb-2 uppercase tracking-widest text-xs">Supported technologies & skills</p>
      <p class="text-zinc-600 mb-6">Each technology auto-installs these skills from <a href="https://skills.sh" target="_blank" rel="noopener" class="text-zinc-400 underline underline-offset-2 decoration-zinc-700 hover:decoration-zinc-400 transition-colors">skills.sh</a>.</p>
      <div class="space-y-0">
        {skillsMap.map((tech) => (
          <div class="group border-b border-zinc-800/40 py-2.5 first:border-t">
            <div class="flex items-start gap-3">
              <div class="flex items-center gap-2 w-32 shrink-0 pt-px">
                {INLINE_SVGS[tech.name] ? (
                  <span class={`w-3.5 h-3.5 shrink-0 opacity-50 group-hover:opacity-100 transition-opacity [&>svg]:w-full [&>svg]:h-full`} set:html={INLINE_SVGS[tech.name]} />
                ) : svgMap[tech.name] ? (
                  <img
                    src={svgMap[tech.name]}
                    alt=""
                    width="14"
                    height="14"
                    class={`w-3.5 h-3.5 shrink-0 opacity-50 group-hover:opacity-100 transition-opacity${tech.name === 'Expo' ? ' brightness-0 invert' : ''}`}
                    loading="lazy"
                  />
                ) : (
                  <span class="w-3.5 h-3.5 shrink-0"></span>
                )}
                <span class="text-zinc-300 group-hover:text-zinc-100 transition-colors text-xs">{tech.name}</span>
              </div>
              <div class="flex-1 min-w-0">
                {tech.skills.length > 0 ? (
                  <div class="flex flex-wrap gap-x-3 gap-y-0.5">
                    {tech.skills.map((skill) => (
                      <a
                        href={skill.startsWith('http') ? skill : `https://skills.sh/${skill}`}
                        target="_blank"
                        rel="noopener"
                        class="text-xs text-zinc-600 hover:text-cyan-400 transition-colors"
                      >{skill.startsWith('http') ? new URL(skill).hostname + new URL(skill).pathname : skill.split('/').slice(2).join('/')}</a>
                    ))}
                  </div>
                ) : (
                  <span class="text-xs text-zinc-700 italic">no skills yet</span>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Separator -->
    <div class="text-zinc-700 mb-12">{'─'.repeat(48)}</div>

    <!-- Options -->
    <div class="mb-12">
      <p class="text-zinc-600 mb-6 uppercase tracking-widest text-xs">Options</p>
      <div class="space-y-2">
        <div class="flex gap-2">
          <span class="text-cyan-400 w-32 shrink-0">-y, --yes</span>
          <span class="text-zinc-500">Skip confirmation prompt</span>
        </div>
        <div class="flex gap-2">
          <span class="text-cyan-400 w-32 shrink-0">--dry-run</span>
          <span class="text-zinc-500">Show skills without installing</span>
        </div>
        <div class="flex gap-2">
          <span class="text-cyan-400 w-32 shrink-0">-h, --help</span>
          <span class="text-zinc-500">Show help message</span>
        </div>
      </div>
    </div>

    <!-- Separator -->
    <div class="text-zinc-700 mb-12">{'─'.repeat(48)}</div>

    <!-- Footer -->
    <footer class="text-zinc-600 space-y-1 pb-8">
      <p>Made by <a href="https://midu.dev" target="_blank" rel="noopener" class="text-zinc-400 underline underline-offset-2 decoration-zinc-700 hover:decoration-zinc-400 transition-colors">midudev</a></p>
      <p>
        <a href="https://github.com/midudev/autoskills.sh" target="_blank" rel="noopener" class="text-zinc-500 underline underline-offset-2 decoration-zinc-700 hover:decoration-zinc-400 hover:text-zinc-300 transition-colors">github</a>
      </p>
    </footer>

  </main>

  <script>
    // ── Copy button ───────────────────────────────────────────
    document.getElementById('copy-btn')?.addEventListener('click', async () => {
      await navigator.clipboard.writeText('npx autoskills')
      const btn = document.getElementById('copy-btn')
      if (btn) {
        btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>`
        setTimeout(() => {
          btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>`
        }, 2000)
      }
    })

    document.getElementById('install-cmd')?.addEventListener('click', async (e) => {
      if ((e.target as HTMLElement).closest('#copy-btn')) return
      await navigator.clipboard.writeText('npx autoskills')
    })

    // ── ASCII logo animation ─────────────────────────────────
    {
      const LOGO_LINES = [
        ' █████╗ ██╗   ██╗████████╗ ██████╗ ███████╗██╗  ██╗██╗██╗     ██╗     ███████╗',
        '██╔══██╗██║   ██║╚══██╔══╝██╔═══██╗██╔════╝██║ ██╔╝██║██║     ██║     ██╔════╝',
        '███████║██║   ██║   ██║   ██║   ██║███████╗█████╔╝ ██║██║     ██║     ███████╗',
        '██╔══██║██║   ██║   ██║   ██║   ██║╚════██║██╔═██╗ ██║██║     ██║     ╚════██║',
        '██║  ██║╚██████╔╝   ██║   ╚██████╔╝███████║██║  ██╗██║███████╗███████╗███████║',
        '╚═╝  ╚═╝ ╚═════╝    ╚═╝    ╚═════╝ ╚══════╝╚═╝  ╚═╝╚═╝╚══════╝╚══════╝╚══════╝',
      ]

      const START_COLOR = '#3f3f46'  // zinc-700 (gris clarito)
      const END_COLOR = '#f4f4f5'    // zinc-100 (blanco)

      const logo = document.getElementById('ascii-logo')!
      const cols = Math.max(...LOGO_LINES.map(l => l.length))
      const rows = LOGO_LINES.length

      // Build grid
      const grid: HTMLSpanElement[][] = []
      for (const line of LOGO_LINES) {
        const row: HTMLSpanElement[] = []
        const lineEl = document.createElement('div')
        lineEl.style.height = '1lh'
        for (let c = 0; c < cols; c++) {
          const ch = line[c] ?? ' '
          const span = document.createElement('span')
          span.textContent = ch
          span.style.color = START_COLOR
          lineEl.appendChild(span)
          row.push(span)
        }
        logo.appendChild(lineEl)
        grid.push(row)
      }

      // Diagonal sweep: top-left to bottom-right, gray → white
      const maxDist = cols + rows
      const SPEED = 0.9
      let frame = 0
      const totalFrames = Math.ceil((maxDist + 10) / SPEED)

      function animate() {
        const waveFront = frame * SPEED

        for (let r = 0; r < rows; r++) {
          for (let c = 0; c < grid[r].length; c++) {
            const dist = c + r * 3
            const progress = Math.max(0, Math.min(1, (waveFront - dist) / 10))

            const gray = Math.round(63 + progress * (244 - 63))
            grid[r][c].style.color = `rgb(${gray},${gray},${gray})`
          }
        }

        frame++
        if (frame <= totalFrames) {
          requestAnimationFrame(animate)
        } else {
          for (let r = 0; r < rows; r++)
            for (let c = 0; c < grid[r].length; c++)
              grid[r][c].style.color = END_COLOR
        }
      }

      requestAnimationFrame(animate)
    }

    // ── Terminal animation ────────────────────────────────────
    const C = {
      z1: 'color:#e4e4e7',  // zinc-200
      z4: 'color:#a1a1aa',  // zinc-400
      z5: 'color:#71717a',  // zinc-500
      z6: 'color:#52525b',  // zinc-600
      z7: 'color:#3f3f46',  // zinc-700
      cy: 'color:#22d3ee',  // cyan-400
      c3: 'color:#67e8f9',  // cyan-300
      em: 'color:#34d399',  // emerald-400
      wh: 'color:#f4f4f5',  // zinc-100
      gn: 'color:#22c55e',  // green-500
    }

    function s(style: string, text: string) {
      return `<span style="${style}">${text}</span>`
    }

    type Step = { html: string; delay: number; class?: string } | { type: 'char'; text: string; target: string; charDelay: number; delay: number }

    const BANNER = [
      s(C.cy, '   ╔═══════════════════════════════════════╗'),
      s(C.cy, '   ║') + s(C.wh, '   autoskills                          ') + s(C.cy, '║'),
      s(C.cy, '   ║') + s(C.z5, '   Auto-install the best AI skills     ') + s(C.cy, '║'),
      s(C.cy, '   ║') + s(C.z5, '   for your project                    ') + s(C.cy, '║'),
      s(C.cy, '   ╚═══════════════════════════════════════╝'),
    ]

    const TECHS = [
      s(C.em, '     ✔ Next.js'),
      s(C.em, '     ✔ React'),
      s(C.em, '     ✔ Tailwind CSS'),
      s(C.em, '     ✔ TypeScript'),
      s(C.em, '     ✔ Supabase'),
      s(C.em, '     ✔ Astro'),
    ]

    const SKILLS = [
      s(C.z6, '    1.') + ' ' + s(C.c3, 'vercel-react-best-practices') + '          ' + s(C.z7, '← React'),
      s(C.z6, '    2.') + ' ' + s(C.c3, 'vercel-composition-patterns') + '          ' + s(C.z7, '← React'),
      s(C.z6, '    3.') + ' ' + s(C.c3, 'next-best-practices') + '                  ' + s(C.z7, '← Next.js'),
      s(C.z6, '    4.') + ' ' + s(C.c3, 'next-cache-components') + '                ' + s(C.z7, '← Next.js'),
      s(C.z6, '    5.') + ' ' + s(C.c3, 'next-upgrade') + '                         ' + s(C.z7, '← Next.js'),
      s(C.z6, '    6.') + ' ' + s(C.c3, 'astro') + '                                ' + s(C.z7, '← Astro'),
      s(C.z6, '    7.') + ' ' + s(C.c3, 'tailwind-css-patterns') + '                ' + s(C.z7, '← Tailwind CSS'),
      s(C.z6, '    8.') + ' ' + s(C.c3, 'typescript-advanced-types') + '            ' + s(C.z7, '← TypeScript'),
      s(C.z6, '    9.') + ' ' + s(C.c3, 'supabase-postgres-best-practices') + '     ' + s(C.z7, '← Supabase'),
      s(C.z6, '   10.') + ' ' + s(C.c3, 'frontend-design') + '                      ' + s(C.z7, '← Frontend'),
    ]

    const INSTALLS = [
      { skill: 'vercel-react-best-practices' },
      { skill: 'vercel-composition-patterns' },
      { skill: 'next-best-practices' },
      { skill: 'next-cache-components' },
      { skill: 'next-upgrade' },
      { skill: 'astro' },
      { skill: 'tailwind-css-patterns' },
      { skill: 'typescript-advanced-types' },
      { skill: 'supabase-postgres-best-practices' },
      { skill: 'frontend-design' },
    ]

    function buildSteps(): Step[] {
      const steps: Step[] = []
      const d = (delay: number, html: string, cls?: string) =>
        steps.push({ html, delay, class: cls })

      // Typing the command
      steps.push({ type: 'char', text: '$ npx autoskills', target: 'cmd-line', charDelay: 60, delay: 400 })

      // Banner
      d(500, '')
      for (const line of BANNER) d(30, line)

      // Detected
      d(400, '')
      d(0, s(C.wh, '   Detected technologies:'))
      d(200, '')
      for (const t of TECHS) d(120, t)

      // Skills header
      d(400, '')
      d(0, s(C.wh, '   Skills to install ') + s(C.z6, '(10)') + s(C.wh, ':'))
      d(200, '')
      for (const r of SKILLS) d(100, r)

      // Prompt + answer
      d(400, '   Install ' + s(C.wh, '10') + ' skills? ' + s(C.z6, '[Y/n]') + ' <span id="term-cursor" class="animate-pulse" style="' + C.z4 + '">▋</span>')
      d(800, '__ANSWER_Y__')

      // Installation
      d(300, '')
      for (const inst of INSTALLS) {
        d(0, '__SPINNER__' + inst.skill)
        d(400 + Math.random() * 500, '__DONE__' + JSON.stringify(inst))
      }

      // Summary
      d(400, '')
      d(0, s(C.gn, '   ✔ Done! 10 skills installed.'))

      return steps
    }

    async function sleep(ms: number) {
      return new Promise(r => setTimeout(r, ms))
    }

    async function runAnimation() {
      const body = document.getElementById('term-body')!
      body.innerHTML = ''

      const steps = buildSteps()

      for (const step of steps) {
        if ('type' in step && step.type === 'char') {
          const line = document.createElement('p')
          line.id = step.target
          body.appendChild(line)
          const cursor = '<span class="animate-pulse" style="' + C.z4 + '">▋</span>'
          for (let i = 0; i < step.text.length; i++) {
            const ch = step.text[i]
            const sofar = step.text.slice(0, i + 1)
            const colored = sofar.startsWith('$ ')
              ? '<span style="' + C.z6 + '">$ </span><span style="' + C.z4 + '">' + sofar.slice(2) + '</span>'
              : sofar
            line.innerHTML = colored + cursor
            await sleep(step.charDelay)
          }
          line.innerHTML = '<span style="' + C.z6 + '">$ </span><span style="' + C.z4 + '">npx autoskills</span>'
          await sleep(step.delay)
          continue
        }

        const { html, delay } = step as { html: string; delay: number; class?: string }

        // Special: answer Y
        if (html === '__ANSWER_Y__') {
          const cursor = document.getElementById('term-cursor')
          if (cursor) cursor.outerHTML = s(C.wh, 'Y')
          await sleep(delay)
          continue
        }

        // Special: spinner
        if (html.startsWith('__SPINNER__')) {
          const skill = html.replace('__SPINNER__', '')
          const line = document.createElement('p')
          line.id = 'install-line'
          line.innerHTML = s(C.z6, '   ◌ ') + s(C.z5, skill + '...')
          body.appendChild(line)
          body.scrollTop = body.scrollHeight
          await sleep(delay)
          continue
        }

        // Special: done
        if (html.startsWith('__DONE__')) {
          const inst = JSON.parse(html.replace('__DONE__', ''))
          const line = document.getElementById('install-line')
          if (line) {
            line.innerHTML = s(C.em, '   ✔ ' + inst.skill)
            line.removeAttribute('id')
          }
          body.scrollTop = body.scrollHeight
          await sleep(delay)
          continue
        }

        const line = document.createElement('p')
        line.innerHTML = html
        if ((step as any).class) line.className = (step as any).class
        body.appendChild(line)
        body.scrollTop = body.scrollHeight
        if (delay > 0) await sleep(delay)
      }
    }

    // Desktop: start immediately. Mobile: start when terminal scrolls into view.
    const terminal = document.getElementById('terminal')
    const isDesktop = window.matchMedia('(min-width: 1024px)').matches

    async function loop() {
      while (true) {
        await runAnimation()
        await sleep(4000)
      }
    }

    if (isDesktop) {
      loop()
    } else if (terminal) {
      let running = false
      const observer = new IntersectionObserver(async (entries) => {
        if (entries[0].isIntersecting && !running) {
          running = true
          observer.disconnect()
          loop()
        }
      }, { threshold: 0.3 })
      observer.observe(terminal)
    }
  </script>
</Layout>
